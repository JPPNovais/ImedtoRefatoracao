# URL base da API.
# - Em DEV: deixe vazio ou comente — o proxy do Vite redireciona /api → http://localhost:5050.
# - Em PROD (Vercel): defina como a URL pública do backend, sem o /api no final.
#   Ex: VITE_API_BASE_URL=https://imedtorefatoracao.onrender.com
# O httpClient e o realtimeService concatenam /api e /hubs/* automaticamente.
# VITE_API_BASE_URL=https://sua-api.com

# Todas as credenciais (JWT, banco, S3) ficam SOMENTE no backend (appsettings.json ou variáveis
# de ambiente do servidor). O frontend nunca recebe segredo — este é o padrão BFF.
