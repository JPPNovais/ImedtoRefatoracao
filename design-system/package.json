{
  "name": "@imedto/ui",
  "version": "0.1.0",
  "description": "Imedto Design System — Vue 3 + shadcn-vue",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/style.css",
    "./tailwind": "./src/tailwind/preset.js"
  },
  "files": [
    "dist",
    "src/tailwind",
    "src/styles"
  ],
  "scripts": {
    "playground": "vite --config vite.playground.config.ts",
    "build": "vue-tsc -p tsconfig.build.json && vite build",
    "dev": "vite build --watch",
    "type-check": "vue-tsc -p tsconfig.build.json --noEmit"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0",
    "vue": ">=3.5.0"
  },
  "dependencies": {
    "@internationalized/date": "^3.5.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^0.564.0",
    "reka-ui": "^2.8.0",
    "tailwind-merge": "^3.4.0",
    "vue-sonner": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.32",
    "vue-tsc": "^2.2.10"
  }
}
