# Caddyfile — TLS automático via Let's Encrypt + reverse proxy.
{
    email contato.imedto@gmail.com
}

app.imedto.com, imedto.com, www.imedto.com {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # API REST
    handle /api/* {
        reverse_proxy backend:5000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # SignalR (WebSocket)
    handle /hubs/* {
        reverse_proxy backend:5000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # Healthcheck público (não protegido) — /health e /health/ready
    handle /health* {
        reverse_proxy backend:5000
    }

    # SPA — frontend nginx
    handle {
        reverse_proxy frontend:80
    }

    log {
        output stdout
        format console
    }
}
