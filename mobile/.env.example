# Base URL da API do backend Imedto.
# MVP: por padrão o app aponta para PRODUÇÃO (https://app.imedto.com).
#  - Build nativo/produção: ver .env.production (já aponta para prod).
#  - Dev no browser: deixe vazio para usar o proxy do Vite (ver .env.development).
#  - Para usar staging/local, sobrescreva aqui (tem prioridade).
VITE_API_BASE_URL=https://app.imedto.com

# Alvo do proxy de dev do Vite (apenas dev no navegador).
VITE_API_PROXY_TARGET=https://app.imedto.com

# Modo mock (apenas dev/preview) — nunca em produção.
# VITE_USE_MOCKS=true
